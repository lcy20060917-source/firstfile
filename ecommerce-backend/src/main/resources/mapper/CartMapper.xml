<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ecommerce.repository.CartRepository">

    <resultMap id="cartItemMap" type="com.ecommerce.domain.CartItem">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="productId" column="product_id"/>
        <result property="quantity" column="quantity"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="productName" column="product_name"/>
        <result property="productPrice" column="product_price"/>
        <result property="productImageUrl" column="product_image_url"/>
    </resultMap>

    <select id="findByUserId" resultMap="cartItemMap">
        SELECT c.*, p.name AS product_name, p.price AS product_price, p.image_url AS product_image_url
        FROM t_cart_item c
        LEFT JOIN t_product p ON c.product_id = p.id
        WHERE c.user_id = #{userId}
        ORDER BY c.create_time DESC
    </select>

    <select id="findByUserIdAndProductId" resultMap="cartItemMap">
        SELECT * FROM t_cart_item
        WHERE user_id = #{userId} AND product_id = #{productId}
    </select>

    <insert id="insert" parameterType="com.ecommerce.domain.CartItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_cart_item (user_id, product_id, quantity)
        VALUES (#{userId}, #{productId}, #{quantity})
    </insert>

    <update id="updateQuantity" parameterType="com.ecommerce.domain.CartItem">
        UPDATE t_cart_item SET quantity = #{quantity}, update_time = CURRENT_TIMESTAMP WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM t_cart_item WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM t_cart_item WHERE user_id = #{userId}
    </delete>

    <delete id="deleteByUserIdAndProductId">
        DELETE FROM t_cart_item WHERE user_id = #{userId} AND product_id = #{productId}
    </delete>

</mapper>
